# Servidor
RETORNO_PORT=3001
JWT_SECRET=cambia-esto-en-produccion

# Dominios
SITE_URL=http://localhost:3001
APP_URL=http://app.localhost:3001
SITE_DOMAIN=retorno.cl
APP_DOMAIN=app.retorno.cl
# REDIRECT_APP_SUBDOMAIN=true

# Admin (se crea automáticamente al iniciar si no existe)
ADMIN_EMAIL=admin@retorno.cl
ADMIN_PASSWORD=admin123
ADMIN_NOMBRE=Administrador

# SMTP — correo al recibir ofertas
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=tu-app-password
SMTP_FROM=Retorno Maquinaria <noreply@retorno.cl>

# Hosts adicionales para subdominio app (separados por coma)
# APP_HOSTS=app.localhost

# MercadoPago (credenciales TEST desde developers.mercadopago.cl)
MP_ACCESS_TOKEN=TEST-xxx
MP_PUBLIC_KEY=TEST-xxx

# Comisión plataforma (%) y plazo confirmación entrega (horas)
COMISION_PCT=12
AUTO_CONFIRM_HOURS=24
